<ui:UXML xmlns:ui="UnityEngine.UIElements" editor-extension-mode="True">
    <ui:VisualElement name="example-drag-root" class="example-root">
        <ui:VisualElement name="example-drag-panel" class="example-panel">
            <ui:VisualElement name="drag-surface" class="example-card" />
            <ui:Label name="drag-status" text="Drag: idle" class="example-status" />
        </ui:VisualElement>
    </ui:VisualElement>
</ui:UXML>
